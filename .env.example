# --- LLM Provider Options (Choose One) ---
# OpenAI API Key (if using gpt-4o)
OPENAI_API_KEY="your-openai-api-key-here"

# Anthropic API Key (if using claude-3-5-sonnet)
# ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# --- Search API Options (Choose One) ---
# Tavily API Key for Agent Web Search
TAVILY_API_KEY="your-tavily-api-key-here"

# --- Vector Database ---
# Pinecone API Key for semantic search of Job Descriptions
PINECONE_API_KEY="your-pinecone-api-key-here"
PINECONE_INDEX_NAME="resume-screener"

# --- LangSmith (Optional but highly recommended for agent tracing) ---
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your-langchain-api-key-here"
LANGCHAIN_PROJECT="ai-resume-screener"

# --- Notion API (for Output Dashboard) ---
NOTION_API_KEY="your-notion-api-key-here"
NOTION_DATABASE_ID="your-notion-database-id-here"
